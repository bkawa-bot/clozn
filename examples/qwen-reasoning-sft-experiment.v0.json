{
  "schema_version": "clozn.experiment.v0",
  "name": "qwen2.5-0.5b-reasoning-sft-smoke",
  "baseline_variant": "base",
  "seeds": [0],
  "defaults": {
    "max_tokens": 256,
    "temperature": 0
  },
  "variants": [
    {
      "name": "base",
      "kind": "base",
      "base_url": "http://127.0.0.1:18081",
      "model": "Qwen2.5-0.5B-Instruct-Q4_K_M"
    },
    {
      "name": "reasoning-sft",
      "kind": "tuned",
      "base_url": "http://127.0.0.1:18082",
      "model": "Reasoning-0.5b-Q4_K_M"
    }
  ],
  "suites": {
    "target": {
      "cases": [
        {
          "name": "syllogism-no-overlap",
          "prompt": "All glims are plons. No plons are dravs. Can any glim be a drav? Explain and answer yes or no.",
          "expect": {
            "contains": "No",
            "not_contains": "Yes"
          }
        }
      ]
    },
    "guard": {
      "cases": [
        {
          "name": "structured-json",
          "prompt": "Return only valid JSON with keys answer and units for this question: how many minutes are in two hours?",
          "expect": {
            "matches": "(?s)^\\s*(```json\\s*)?\\{\\s*\"answer\"\\s*:\\s*120,\\s*\"units\"\\s*:\\s*\"minutes\"\\s*\\}\\s*(```)?\\s*$"
          }
        },
        {
          "name": "capital-fact",
          "prompt": "What is the capital of France?",
          "expect": {
            "contains": "Paris",
            "not_contains": "Berlin"
          }
        }
      ]
    }
  }
}
