{
  "schema_version": "clozn.experiment.v0",
  "name": "concise-prompt-with-guard",
  "baseline_variant": "base",
  "seeds": [7, 19, 42],
  "defaults": {
    "base_url": "http://127.0.0.1:8080",
    "model": "clozn",
    "max_tokens": 128,
    "temperature": 0.8,
    "top_p": 0.9
  },
  "variants": [
    {
      "name": "base",
      "kind": "base"
    },
    {
      "name": "concise-prompt",
      "kind": "prompt",
      "system_prompt": "Answer directly and concisely."
    }
  ],
  "suites": {
    "target": {
      "cases": [
        {
          "name": "short-capital-answer",
          "prompt": "What is the capital of France?",
          "expect": {
            "contains": "Paris",
            "not_contains": "Berlin",
            "finish_reason": "stop"
          }
        }
      ]
    },
    "guard": {
      "cases": [
        {
          "name": "keeps-essential-context",
          "prompt": "Name the three primary colors.",
          "expect": {
            "contains": ["red", "blue", "yellow"]
          }
        }
      ]
    }
  }
}
