     LLAMA_API float * llama_get_logits(struct llama_context * ctx);
 
+    // CLOZE PATCH (additive; see core/third_party/PATCHES.md). The device-resident logits
+    // graph-output tensor from the last llama_decode(). On a GPU backend (GGML_CUDA) its ->data
+    // is a raw device pointer to the [n_outputs, n_vocab] logits — for a zero-copy on-device
+    // confidence-select that avoids the full-vocab D2H copy. Valid after llama_decode (the call
+    // synchronizes); the buffer is reused on the next decode, so consume it before then. NULL if
+    // no decode has run. Guard residency with ggml_backend_buffer_is_host(t->buffer).
+    LLAMA_API struct ggml_tensor * llama_get_logits_tensor(struct llama_context * ctx);
+
+    // CLOZE PATCH (additive; see core/third_party/PATCHES.md). When skip=true, subsequent
+    // llama_decode() calls skip the device->host raw-logits copy — for callers that consume
+    // llama_get_logits_tensor() on-device (zero-copy confidence-select), so the full-vocab logits
+    // never cross the bus. While set, llama_get_logits()/_ith() return stale data. Default false.
+    LLAMA_API void llama_set_skip_raw_logits(struct llama_context * ctx, bool skip);
+
     // Logits for the ith token. For positive indices, Equivalent to:
     // llama_get_logits(ctx) + ctx->output_ids[i]*n_vocab
     // Negative indices can be used to access logits in reverse order, -1 is the last logit.
