 }
 
+// CLOZE PATCH (additive; see core/third_party/PATCHES.md). Synchronize (so the compute that
+// produced the logits has finished), then hand back the device-resident graph-output tensor
+// instead of the host copy. The caller reads tensor->data (a device pointer under GGML_CUDA)
+// and must consume it before the next llama_decode reuses the buffer.
+struct ggml_tensor * llama_get_logits_tensor(llama_context * ctx) {
+    ctx->synchronize();
+
+    return ctx->get_logits_tensor();
+}
+
+// CLOZE PATCH (additive; see core/third_party/PATCHES.md).
+void llama_set_skip_raw_logits(llama_context * ctx, bool skip) {
+    ctx->set_skip_raw_logits(skip);
+}
