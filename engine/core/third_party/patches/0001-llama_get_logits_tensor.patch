+// CLOZE PATCH (additive; see core/third_party/PATCHES.md): the device-resident t_logits
+// graph-output tensor from the previous decode, or nullptr if none. Does NOT reorder/copy —
+// returns the raw graph output (rows in graph order, not output_ids order). The caller pairs it
+// with the active-block positions it requested and reads tensor->data after a synchronize.
+ggml_tensor * llama_context::get_logits_tensor() const {
+    return gf_res_prev ? gf_res_prev->get_logits() : nullptr;
+}
